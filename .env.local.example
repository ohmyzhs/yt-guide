# /api/gemini-generate now runs through the local `claude` CLI (no Gemini API
# costs when the machine is logged in via `claude login`). The two GEMINI_*
# vars below are no longer used by the route — kept here only for reference
# in case you want to revert via git.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Optional: pin a specific Claude model. Leave blank to use the CLI default
# (whatever the logged-in account is configured for).
# Examples: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5
CLAUDE_MODEL=

# Per-request timeout for /api/gemini-generate (milliseconds).
CLAUDE_GENERATE_TIMEOUT_MS=180000

# Blog builder integration (only used when self-hosted on the Windows PC)
# Absolute path to claude-code-blog-builder repo on this machine.
# Windows: C:\workspace\claude-code-blog-builder
# macOS:   /Users/me/Documents/Workspace/blog/claude-code-blog-builder
BLOG_BUILDER_PATH=

# claude CLI binary name. Leave blank to auto-pick (claude.cmd on Windows, claude elsewhere).
# Set to an absolute path if `claude` is not on PATH.
CLAUDE_BIN=

# Permission mode for headless `claude -p` execution.
# bypassPermissions: auto-approve all tools (required for /blog-new pipeline).
CLAUDE_PERMISSION_MODE=bypassPermissions
